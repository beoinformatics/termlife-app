    "@vitest/coverage-v8": "^4.0.18",
    "electron": "^33.0.0",
    "electron-vite": "^2.3.0",
    "typescript": "^5.6.0",
    "vite": "^5.0.0",
    "vitest": "^4.0.18"
  }
}
